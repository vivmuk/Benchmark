__pycache__/
*.pyc

# Per-brick test output lives in arcade/ alongside index.html; allow real bricks,
# but ignore small synthetic placeholders so a partial run doesn't pollute the repo.
# Threshold: real bricks are > 1000 bytes; dry-run placeholders are ~330 bytes.
arcade/*.raw.txt

# Don't commit the in-progress brick_arcade.json from a partial run
benchmarks/venice-benchmark-site/data/brick_arcade.json.tmp
